# SynapzCore — Environment variables (preferred over data/supabase_config.json)
#
# Copy this file to `.env` and fill in real values, OR export these in your shell.
# When SUPABASE_URL and SUPABASE_KEY are both set, the code uses them and
# ignores data/supabase_config.json entirely — keeping secrets out of files.
#
# Both the Rust layer (synapz-memory) and the Python layer (synapz_memory.py,
# graph_memory.py, dream_compression.py) read these.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key-here

# Optional: override repo root (defaults to E:\AGT_Brain)
# SYNAPZ_ROOT=E:\AGT_Brain
